<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Clairjour makes no network calls today. Block cleartext by default to guard
         against any regression that would silently ship data unencrypted. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
